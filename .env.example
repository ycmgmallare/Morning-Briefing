# Morning Briefing — environment variables (copy to .env and fill in).
# .env is gitignored; never commit real keys. On Render, set these in the
# dashboard instead of committing them.

# Groq API (default provider) — free key at https://console.groq.com/keys ("gsk_").
GROQ_API_KEY=

# Claude (Anthropic) API — only needed when AI_PROVIDER=claude. Keys start "sk-ant-".
ANTHROPIC_API_KEY=

# Supabase (real mode) — project URL + API key for the `signups` table.
SUPABASE_URL=
SUPABASE_KEY=

# Resend (default email provider). RESEND_FROM must be a verified-domain address
# for real delivery; "onboarding@resend.dev" only reaches the account owner.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_TO=

# Gmail SMTP (alternative provider — only needed if EMAIL_PROVIDER=gmail).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Web console auth + Vercel cron (used by app.js / api/cron.js when deployed)
CONSOLE_USER=admin           # Basic-Auth username for the deployed console
CONSOLE_PASSWORD=            # set this on Vercel to lock the console; blank = open (local)
CRON_SECRET=                 # shared secret Vercel Cron sends to /api/cron

# Behaviour
AI_PROVIDER=groq             # groq (free) | claude
EMAIL_PROVIDER=resend        # gmail | resend
BRIEFING_MODE=demo           # demo | real
BRIEFING_CRON=0 7 * * *      # local scheduler.mjs only (Render uses render.yaml)
BRIEFING_TZ=Asia/Manila      # cron timezone + "yesterday" window for Supabase
